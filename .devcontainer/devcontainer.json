{
  "name": "Tailscale ExitNode",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "privileged": true,
  "capAdd": [
    "NET_ADMIN",
    "NET_RAW"
  ],
  "features": {
    "ghcr.io/tailscale/codespace/tailscale": {
      "version": "latest"
    }
  },
  "postStartCommand": [
    "sleep 5",
    "sudo tailscale up --reset --tun=userspace-networking --authkey=${TAILSCALE_AUTHKEY} --accept-routes --exit-node --exit-node-allow-lan-access"
  ],
  "remoteUser": "codespace"
}
