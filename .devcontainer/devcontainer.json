{
  "name": "Tailscale ExitNode",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "privileged": true,
  "capAdd": [
    "NET_ADMIN",
    "NET_RAW"
  ],
  "features": {
    "ghcr.io/tailscale/codespace/tailscale": {
      "version": "latest"
    }
  },
  "postStartCommand": [
    "sleep 2",
    "sudo tailscale up --reset --tun=userspace-networking --authkey=tskey-auth-kzBupQZ4Q611CNTRL-5eYGQRy9VA8aoHgxVvGFA8MHL15BT19oK --accept-routes --exit-node=CodeSpace-ExitNode --exit-node-allow-lan-access"
  ],
  "remoteUser": "codespace"
}
