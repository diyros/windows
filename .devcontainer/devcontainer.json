{
  "name": "Tailscale ExitNode ",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "privileged": true,
  "capAdd": [
    "NET_ADMIN",
    "NET_RAW"
  ],
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:2.1.0": {"version": "lts"} 
  },
  "postCreateCommand": [
    "curl -fsSL https://tailscale.com/install.sh | sh",
    "sudo tailscaled --tun=userspace-networking --state=/tmp/tailscale.state --socket=/tmp/tailscale.sock > /tmp/ts.log 2>&1 &",
    "sleep 5",
    "sudo tailscale up --authkey=tskey-auth-kzBupQZ4Q611CNTRL-5eYGQRy9VA8aoHgxVvGFA8MHL15BT19oK --accept-routes --exit-node=CodeSpace-ExitNode --exit-node-allow-lan-access"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "GitHub.copilot"
      ]
    }
  },
  "remoteUser": "codespace"
}